    # ══════════════════════════════════════════════════════════
    # PART 5 — SOCIAL NETWORK ANALYSIS & GRAPH MINING
    # ══════════════════════════════════════════════════════════
    S.append(banner("PART 5 — SOCIAL NETWORK ANALYSIS (SNA) &amp; GRAPH MINING"))
    S.append(Spacer(1, 10))

    S += Q(22,
        "What is Social Network Analysis (SNA)? Define its core components — nodes and edges — and explain what each represents in a social media context.",
        [
            "Social Network Analysis (SNA) is a mathematical and computational methodology for studying social structures by representing them as networks (mathematical graphs). It maps and measures the relationships, flows of information, and patterns of interaction between entities in a system.",
            "",
            "SNA originated in sociology and has been adopted across computer science, marketing, epidemiology, and intelligence analysis due to its power in revealing hidden structural patterns in complex systems.",
            "",
            "Core Components:",
            "",
            "Nodes (also called Vertices or Actors): Represent the individual entities in the network. In a social media context:",
            "- In a friendship network: each node = one person (user account).",
            "- In a web link network: each node = one webpage.",
            "- In a collaboration network: each node = one researcher or organisation.",
            "- In a company's customer network: each node = one customer.",
            "",
            "Edges (also called Links, Ties, or Connections): Represent the relationships or interactions between nodes. In a social media context:",
            "- Facebook friendship edge: bidirectional (mutual) — if A is friends with B, B is also friends with A.",
            "- Twitter follow edge: directional — A can follow B without B following A.",
            "- Email edge: A sent a message to B.",
            "- Co-authorship edge: two researchers published a paper together.",
            "",
            "Together, nodes and edges form a graph that can be mathematically analysed to reveal: who is most influential, how information flows, which groups cluster together, and where the network's critical points of connection lie.",
        ],
        "SNA = Graph Theory + Social Data. Nodes = people/entities. Edges = relationships. Directed edges (Twitter) vs undirected edges (Facebook) is a key distinction.")

    S += Q(23,
        "Explain the difference between Directed and Undirected graphs. Give a social media example of each. What are in-degree and out-degree?",
        [
            "Undirected Graph: A graph where edges have no direction. If node A is connected to node B, then B is equally connected to A. The relationship is symmetrical and mutual. Every edge represents a bidirectional tie.",
            "Social media example: Facebook friendships. When User A sends a friend request and User B accepts, both users are friends with each other simultaneously. The friendship is mutual — the edge goes both ways.",
            "",
            "Directed Graph (Digraph): A graph where edges have a specific direction. An edge from A to B (written A → B) does NOT necessarily imply an edge from B to A. The relationship can be asymmetrical.",
            "Social media example: Twitter's follow system. User A can follow Celebrity B (A → B), but Celebrity B may not follow User A back. The follower relationship is one-directional.",
            "",
            "In-Degree and Out-Degree (concepts specific to directed graphs):",
            "- In-Degree of node v: The number of directed edges arriving AT node v (edges pointing INTO v). In Twitter terms: the number of followers a user has.",
            "- Out-Degree of node v: The number of directed edges leaving FROM node v (edges pointing AWAY from v). In Twitter terms: the number of accounts a user is following.",
            "",
            "A celebrity with 5,000,000 followers and who follows only 200 accounts has: in-degree = 5,000,000 and out-degree = 200. These are radically different — impossible in an undirected friendship network where they would be equal.",
        ],
        "Undirected = symmetric/mutual (Facebook). Directed = asymmetric (Twitter). In-degree = received connections (followers). Out-degree = sent connections (following).")

    S += Q(24,
        "Define Graph Density. Provide the formula and explain what high and low density mean about a social network.",
        [
            "Graph Density is a measure of how densely connected a network is — it compares the number of actual connections (edges) that exist to the maximum number that could possibly exist between all nodes.",
            "",
            "Formula for Undirected Graph:",
            "Density = E / [ N * (N-1) / 2 ]",
            "Where E = actual number of edges, N = number of nodes.",
            "",
            "Formula for Directed Graph:",
            "Density = E / [ N * (N-1) ]",
            "(Because in directed graphs, A→B and B→A are two separate edges.)",
            "",
            "Value range: Density is always between 0 and 1.",
            "- Density = 1: A complete graph — every node is directly connected to every other node (maximum possible connections).",
            "- Density = 0: An empty graph — no connections at all.",
            "",
            "What density tells us about social networks:",
            "- High Density (close to 1): A tightly-knit, cohesive network where most members know each other. Example: a small, close friend group or a tight professional team.",
            "- Low Density / Sparse (close to 0): A large network where most members have few connections relative to the total possible. This is typical of real-world social networks — even a popular person cannot realistically be personally connected to millions of others.",
            "",
            "Important: Most real-world social networks are sparse. Even massive networks like Facebook have very low overall density because the number of possible connections grows as N*(N-1)/2 but actual connections grow much more slowly.",
        ],
        "Density formula (undirected): D = E / [N(N-1)/2]. Real social networks are sparse (low density). Complete graph density = 1.")

    S += Q(25,
        "Define and explain THREE centrality measures used in Social Network Analysis: Degree Centrality, Betweenness Centrality, and Closeness Centrality. Why is centrality important for organisations?",
        [
            "Centrality measures quantify how important, influential, or strategically positioned a node is within a network. Different centrality measures capture different types of influence.",
            "",
            "1. Degree Centrality: Measures the fraction of nodes that a given node is directly connected to.",
            "Formula: DC(v) = degree(v) / (N-1), where N = total nodes.",
            "Interpretation: A high degree centrality node is a 'hub' — it has direct connections to many others. In a Twitter network, a celebrity with millions of followers has high in-degree centrality.",
            "Organisational use: Identifying hubs helps target the most connected users for marketing messages — their direct reach is maximised.",
            "",
            "2. Betweenness Centrality: Measures how often a node lies on the shortest path between all other pairs of nodes in the network.",
            "Interpretation: A high betweenness node is a 'broker' or 'bridge' — information travelling between different parts of the network must pass through it. Removing a high-betweenness node can disconnect communities that had no other path to each other.",
            "Organisational use: Identifying brokers reveals critical intermediaries (e.g., journalists connecting politicians to the public, or community managers connecting brand to customers).",
            "",
            "3. Closeness Centrality: Measures how quickly a node can reach all other nodes via the shortest paths.",
            "Formula: CC(v) = (N-1) / [sum of all shortest path distances from v to all others].",
            "Interpretation: A high closeness node can spread information to the entire network in fewer steps than others — making it an ideal starting point for viral campaigns.",
            "Organisational use: Targeting high-closeness users with sponsored content maximises how quickly the content spreads through the network.",
            "",
            "Why centrality matters for organisations: By identifying which users are hubs (degree), brokers (betweenness), or fast spreaders (closeness), organisations can design more targeted and cost-efficient influencer marketing, viral campaign seeding, and community management strategies.",
        ],
        "Three centrality types: DEGREE (hub = most connections), BETWEENNESS (broker = bridges gaps), CLOSENESS (spreader = reaches all fastest). Know all three formulas.")

    S += Q(26,
        "What is the Clustering Coefficient? Provide the formula, explain what it measures, and give an example.",
        [
            "The Clustering Coefficient of a node measures the degree to which the neighbours of that node are connected to each other. In other words, it asks: 'What fraction of my neighbours also know each other?' This quantifies the local 'cliquishness' or cohesion of a node's neighbourhood.",
            "",
            "Formula:",
            "CC(v) = actual edges among neighbours / maximum possible edges among neighbours",
            "Where maximum possible edges = k*(k-1)/2, and k = number of neighbours of node v.",
            "",
            "Value range: 0 to 1.",
            "- CC = 1: All neighbours are interconnected — they form a perfect clique (everyone in the group knows everyone else).",
            "- CC = 0: None of the node's neighbours are connected to each other — the node acts as the only bridge between them.",
            "",
            "Example:",
            "User A has 4 friends: B, C, D, E. The maximum possible edges among these 4 friends = 4*3/2 = 6. Suppose B-C are friends and D-E are friends — 2 actual edges. CC(A) = 2/6 ≈ 0.33. This means 33% of A's friends know each other.",
            "",
            "What the clustering coefficient tells us about the network:",
            "- High overall CC → highly clustered network with tight communities (typical of friendship networks where 'friends of friends become friends').",
            "- Low CC for a specific node → that node is a bridge between otherwise disconnected groups — structurally important as a broker.",
            "- The average clustering coefficient of the entire network indicates how 'small-world' the network is.",
        ],
        "Formula: CC(v) = actual_edges / [k(k-1)/2]. High CC = tight community. Low CC = bridge node. The average CC across the whole network measures overall cliquishness.")

    S += Q(27,
        "What is Community Detection in graph mining? Why is it important for organisations studying social media?",
        [
            "Community Detection is the computational process of identifying groups of nodes within a network that are more densely connected internally (to each other) than externally (to the rest of the network). These groups are called communities, clusters, or modules.",
            "",
            "Technically, a community is a subset of nodes where the density of edges within the subset significantly exceeds the density of edges between that subset and the rest of the network.",
            "",
            "Why community detection is important for organisations:",
            "- Market Segmentation: Communities represent natural audience segments with shared interests, demographics, or behaviours. Identifying communities allows organisations to create targeted marketing campaigns tailored to each group's specific characteristics.",
            "- Influencer Marketing: Each community has its own internal influencers — high-centrality nodes within the community's subgraph. Targeting these local influencers is more efficient than targeting generic global hubs.",
            "- Content Personalisation: Understanding which community a user belongs to helps organisations recommend relevant content, products, or connections — the basis of recommendation systems.",
            "- Brand Community Building: Organisations can identify and nurture existing communities of brand advocates, turning organic groups into structured loyal communities.",
            "- Anomaly Detection: Rapidly forming or unusually dense communities may indicate coordinated inauthentic behaviour (bot networks, viral campaigns, or disinformation clusters).",
            "- Network Growth Strategy: Understanding community structure helps organisations identify which communities to enter and how to seed their presence most effectively.",
        ],
        "Community = dense internal connections, sparse external connections. It is the foundation of audience segmentation, influencer identification, and recommendation systems.")

    S += Q(28,
        "Explain what Link Prediction means in Social Network Analysis. Give a real-world example of where it is applied.",
        [
            "Link Prediction is a graph mining task that uses the current structure of a network to predict which new connections (edges) are likely to form in the future — or which missing edges exist but have not yet been observed.",
            "",
            "The core idea: the probability that two currently unconnected nodes will become connected depends on structural features of the network — for example, how many common neighbours they share, how close they are in the network, and how similar their connection patterns are.",
            "",
            "Common Link Prediction metrics:",
            "- Common Neighbours: Nodes that share many mutual connections are more likely to connect. Example: two people who have 15 mutual friends on Facebook are likely to know each other.",
            "- Jaccard Coefficient: Measures the proportion of common neighbours relative to total neighbours.",
            "- Preferential Attachment: Nodes with high degree (hubs) are more likely to attract new connections.",
            "",
            "Real-world applications:",
            "- LinkedIn 'People You May Know': LinkedIn analyses your professional network's structure to predict which professionals you are likely to know or want to connect with.",
            "- Facebook Friend Suggestions: Based on mutual friends and interaction patterns.",
            "- Twitter 'Who to Follow': Recommends accounts based on your current follows and the follows of people similar to you.",
            "- E-commerce Recommendations: 'Customers who bought X also bought Y' — treating customers and products as nodes and purchases as edges, then predicting missing purchase links.",
            "- Research Collaboration: Predicting which researchers are likely to co-author future papers.",
        ],
        "Link prediction = predicting future connections based on current network structure. Real-world example: LinkedIn 'People You May Know' and Facebook friend suggestions.")

    S.append(PageBreak())

    # ══════════════════════════════════════════════════════════
    # PART 6 — MATHEMATICAL PROBLEMS
    # ══════════════════════════════════════════════════════════
    S.append(banner("PART 6 — MATHEMATICAL PROBLEMS: GRAPH THEORY &amp; SNA CALCULATIONS"))
    S.append(Spacer(1, 8))
    S.append(Paragraph(
        "Show all working. State the formula before applying it. "
        "All answers are verified step-by-step.",
        ParagraphStyle('note_p', fontName='Helvetica-Oblique', fontSize=10,
                       textColor=SLATE, leading=14, spaceAfter=12)))

    # ── P1 ─────────────────────────────────────────────────────
    S += Q("1",
        "A social network has 6 nodes: A, B, C, D, E, F. "
        "Edges: A-B, A-C, A-D, B-C, B-E, C-F, D-E, E-F. "
        "Find: (a) degree of each node, (b) total edges, (c) graph density, (d) average degree.",
        [
            "Step 1 — Count connections per node:",
            "  A: B, C, D          → degree(A) = 3",
            "  B: A, C, E          → degree(B) = 3",
            "  C: A, B, F          → degree(C) = 3",
            "  D: A, E             → degree(D) = 2",
            "  E: B, D, F          → degree(E) = 3",
            "  F: C, E             → degree(F) = 2",
            "",
            "Step 2 — Total edges (Handshaking Lemma: sum of degrees / 2):",
            "  Sum = 3+3+3+2+3+2 = 16   →   Edges = 16/2 = 8",
            "",
            "Step 3 — Maximum possible edges (N=6, undirected):",
            "  Max = N*(N-1)/2 = 6*5/2 = 15",
            "  Density = 8/15 ≈ 0.533",
            "",
            "Step 4 — Average degree = Sum of degrees / N = 16/6 ≈ 2.67",
            "FINAL: degrees: A=3, B=3, C=3, D=2, E=3, F=2 | Edges=8 | Density≈0.533 | Avg degree≈2.67",
        ],
        "Handshaking Lemma: ALWAYS divide sum of all degrees by 2 to get the number of edges.",
        math=True)

    # ── P2 ─────────────────────────────────────────────────────
    S += Q("2",
        "Using the network from Problem 1, calculate the Degree Centrality of nodes A, D, and E. "
        "Rank them from highest to lowest centrality.",
        [
            "Formula: DC(v) = degree(v) / (N - 1)",
            "N = 6 nodes, so N-1 = 5",
            "",
            "DC(A) = 3/5 = 0.600",
            "DC(D) = 2/5 = 0.400",
            "DC(E) = 3/5 = 0.600",
            "",
            "FINAL: DC(A) = 0.60 = DC(E) = 0.60 > DC(D) = 0.40",
            "Nodes A and E are equally the most central by degree. D is least central of the three.",
        ],
        "DC formula: degree(v) / (N-1). The denominator is N-1 because a node cannot connect to itself.",
        math=True)

    # ── P3 ─────────────────────────────────────────────────────
    S += Q("3",
        "A directed social network has 5 users: 1, 2, 3, 4, 5. "
        "Directed edges: 1→2, 1→3, 2→4, 3→4, 3→5, 4→5, 5→1. "
        "Calculate: (a) in-degree and out-degree of each user, "
        "(b) the most 'popular' user (highest in-degree), "
        "(c) the most 'active' user (highest out-degree).",
        [
            "Step 1 — In-degree (count arrows ARRIVING at each node):",
            "  User 1: arrow from 5      → in-degree = 1",
            "  User 2: arrow from 1      → in-degree = 1",
            "  User 3: arrow from 1      → in-degree = 1",
            "  User 4: arrows from 2, 3  → in-degree = 2",
            "  User 5: arrows from 3, 4  → in-degree = 2",
            "",
            "Step 2 — Out-degree (count arrows LEAVING each node):",
            "  User 1: 1→2, 1→3          → out-degree = 2",
            "  User 2: 2→4               → out-degree = 1",
            "  User 3: 3→4, 3→5          → out-degree = 2",
            "  User 4: 4→5               → out-degree = 1",
            "  User 5: 5→1               → out-degree = 1",
            "",
            "FINAL: Most popular (highest in-degree): Users 4 and 5 (in-degree = 2, tied). Most active (highest out-degree): Users 1 and 3 (out-degree = 2, tied).",
        ],
        "In-degree = how many point TO you (popularity). Out-degree = how many you point TO (activity). These differ in directed graphs.",
        math=True)

    # ── P4 ─────────────────────────────────────────────────────
    S += Q("4",
        "Calculate the Clustering Coefficient of node M in the following network. "
        "M has 5 neighbours: P, Q, R, S, T. "
        "Edges among M's neighbours: P-Q, P-R, Q-S, R-T.",
        [
            "Step 1 — k = 5 neighbours (P, Q, R, S, T)",
            "Step 2 — Maximum possible edges among 5 neighbours: k*(k-1)/2 = 5*4/2 = 10",
            "Step 3 — List the 10 possible edges: P-Q, P-R, P-S, P-T, Q-R, Q-S, Q-T, R-S, R-T, S-T",
            "Step 4 — Actual edges present: P-Q ✓, P-R ✓, Q-S ✓, R-T ✓  →  4 actual edges",
            "Step 5 — CC(M) = 4/10 = 0.40",
            "FINAL: Clustering Coefficient of node M = 0.40 (40%)",
        ],
        "CC = actual_edges_among_neighbours / [k*(k-1)/2]. Count carefully — only edges BETWEEN neighbours, not edges connecting to M.",
        math=True)

    # ── P5 ─────────────────────────────────────────────────────
    S += Q("5",
        "An undirected network has 10 nodes and 22 edges. "
        "(a) What is the maximum possible number of edges? "
        "(b) What is the graph density? "
        "(c) For a directed version of the same network (with 22 directed edges), what is the directed density?",
        [
            "Part (a) — Max edges (undirected, N=10):",
            "  Max = N*(N-1)/2 = 10*9/2 = 45",
            "",
            "Part (b) — Undirected density:",
            "  Density = 22/45 ≈ 0.489  (approximately 48.9% — sparse)",
            "",
            "Part (c) — Max directed edges (no self-loops): N*(N-1) = 10*9 = 90",
            "  Directed density = 22/90 ≈ 0.244  (approximately 24.4%)",
            "",
            "FINAL: Max undirected edges=45 | Undirected density≈0.489 | Max directed edges=90 | Directed density≈0.244",
        ],
        "Key difference: undirected max = N(N-1)/2. Directed max = N(N-1). The directed max is exactly double the undirected max.",
        math=True)

    # ── P6 ─────────────────────────────────────────────────────
    S += Q("6",
        "Find the shortest path from node A to node G and state its length. "
        "Network edges: A-B, A-C, B-D, C-D, C-E, D-F, E-G, F-G.",
        [
            "Apply BFS (Breadth-First Search) starting from A:",
            "  Level 0: {A}",
            "  Level 1: neighbours of A = {B, C}",
            "  Level 2: unvisited neighbours of B → {D}; unvisited neighbours of C → {D, E}",
            "    New nodes at level 2: {D, E}",
            "  Level 3: unvisited neighbours of D → {F}; unvisited neighbours of E → {G}",
            "    G is found at Level 3 from E!",
            "",
            "Trace back the path to G: A → C → E → G",
            "  Length = 3 hops",
            "",
            "Verify alternative paths:",
            "  A→B→D→F→G = 4 hops  (longer)",
            "  A→C→D→F→G = 4 hops  (longer)",
            "",
            "FINAL: Shortest path = A → C → E → G | Length = 3 edges",
        ],
        "BFS finds shortest paths in unweighted graphs by exploring level by level. Always verify by checking alternative routes.",
        math=True)

    # ── P7 ─────────────────────────────────────────────────────
    S += Q("7",
        "The adjacency matrix below represents an undirected network with nodes 1, 2, 3, 4, 5. "
        "Row 1:[0,1,1,0,0], Row 2:[1,0,1,1,0], Row 3:[1,1,0,0,1], Row 4:[0,1,0,0,1], Row 5:[0,0,1,1,0]. "
        "Find: (a) list all edges, (b) degree of each node, (c) Degree Centrality of node 2, (d) density.",
        [
            "Part (a) — Edges from upper triangle:",
            "  Row 1: 1-2, 1-3",
            "  Row 2: 2-3, 2-4",
            "  Row 3: 3-5",
            "  Row 4: 4-5",
            "  Edges: {1-2, 1-3, 2-3, 2-4, 3-5, 4-5}  →  6 edges",
            "",
            "Part (b) — Degree (sum of row):",
            "  Node 1: 0+1+1+0+0 = 2",
            "  Node 2: 1+0+1+1+0 = 3",
            "  Node 3: 1+1+0+0+1 = 3",
            "  Node 4: 0+1+0+0+1 = 2",
            "  Node 5: 0+0+1+1+0 = 2",
            "",
            "Part (c) — DC(2) = degree(2)/(N-1) = 3/(5-1) = 3/4 = 0.75",
            "",
            "Part (d) — Max edges: 5*4/2 = 10  |  Density = 6/10 = 0.60",
            "FINAL: 6 edges | degrees: 2,3,3,2,2 | DC(2)=0.75 | Density=0.60",
        ],
        "Adjacency matrix: each row sum = node degree. Only read the upper triangle to avoid double-counting edges.",
        math=True)

    # ── P8 ─────────────────────────────────────────────────────
    S += Q("8",
        "Calculate the Closeness Centrality of node X in a network of 7 nodes. "
        "Shortest path distances from X: d(X,A)=1, d(X,B)=2, d(X,C)=1, d(X,D)=3, d(X,E)=2, d(X,F)=2.",
        [
            "Formula: CC(X) = (N-1) / sum_of_shortest_distances_from_X",
            "",
            "Step 1 — N = 7  →  N-1 = 6",
            "Step 2 — Sum of distances = 1+2+1+3+2+2 = 11",
            "Step 3 — CC(X) = 6/11 ≈ 0.545",
            "",
            "Interpretation: X can reach the rest of the network in an average of 11/6 ≈ 1.83 hops. A closeness of 1.0 would mean direct connection to all others.",
            "FINAL: Closeness Centrality of X ≈ 0.545",
        ],
        "CC formula: (N-1) / sum_of_distances. Higher CC = spreads information faster. Maximum CC = 1.0 (connected to every other node directly).",
        math=True)

    # ── P9 ─────────────────────────────────────────────────────
    S += Q("9",
        "A company's social post starts with 80 initial viewers. Each viewer shares it with exactly 3 new unique people. "
        "Calculate: (a) viewers added in rounds 1, 2, and 3, "
        "(b) total unique viewers after 3 rounds of sharing, "
        "(c) total after 4 rounds.",
        [
            "This is geometric growth: each round multiplies new viewers by sharing factor r=3.",
            "",
            "Round 0 (initial):  80 viewers",
            "Round 1:  80 x 3 = 240 new viewers",
            "Round 2:  240 x 3 = 720 new viewers",
            "Round 3:  720 x 3 = 2,160 new viewers",
            "Round 4:  2,160 x 3 = 6,480 new viewers",
            "",
            "Cumulative total using geometric series formula: Total = Initial x (r^0 + r^1 + ... + r^n)",
            "After 3 rounds: 80 x (1+3+9+27) = 80 x 40 = 3,200",
            "After 4 rounds: 80 x (1+3+9+27+81) = 80 x 121 = 9,680",
            "",
            "FINAL: Round 1=240, Round 2=720, Round 3=2,160 new viewers | Total after 3 rounds = 3,200 | Total after 4 rounds = 9,680",
        ],
        "Formula: Total = Initial * SUM(r^k, k=0 to n). This models viral amplification — the core of social media's 'Reach Audience' advantage.",
        math=True)

    # ── P10 ────────────────────────────────────────────────────
    S += Q("10",
        "A company invests 15,000 EGP in a social media campaign. "
        "The campaign receives 3,000 clicks. Of those, 150 make purchases, each worth 250 EGP. "
        "Calculate: (a) Total Revenue, (b) ROI, (c) CPC, (d) Conversion Rate, (e) CPA.",
        [
            "(a) Total Revenue = conversions x value = 150 x 250 = 37,500 EGP",
            "",
            "(b) ROI = [(Revenue - Cost) / Cost] x 100%",
            "   = [(37,500 - 15,000) / 15,000] x 100%",
            "   = [22,500 / 15,000] x 100% = 150%",
            "",
            "(c) CPC (Cost Per Click) = Total Cost / Clicks = 15,000 / 3,000 = 5 EGP per click",
            "",
            "(d) Conversion Rate = Conversions / Clicks x 100% = 150/3,000 x 100% = 5%",
            "",
            "(e) CPA (Cost Per Acquisition) = Total Cost / Conversions = 15,000 / 150 = 100 EGP per customer",
            "",
            "FINAL: Revenue=37,500 EGP | ROI=150% | CPC=5 EGP | Conversion Rate=5% | CPA=100 EGP",
        ],
        "Five essential digital marketing KPIs: ROI, CPC, CPA, Conversion Rate, Revenue. Know all five formulas.",
        math=True)

    # ── P11 ────────────────────────────────────────────────────
    S += Q("11",
        "A network has nodes {A,B,C,D,E,F,G,H}. Edges: A-B, B-C, C-A, D-E, D-F, E-F, G-H. "
        "Is the network connected or disconnected? "
        "List all connected components and state how many there are.",
        [
            "Start BFS/DFS from node A:",
            "  A → B → C → back to A  (triangle — all visited)",
            "  Component 1: {A, B, C}",
            "",
            "Start from D (not yet visited):",
            "  D → E → F → back to D  (triangle — all visited)",
            "  Component 2: {D, E, F}",
            "",
            "Start from G (not yet visited):",
            "  G → H",
            "  Component 3: {G, H}",
            "",
            "All 8 nodes accounted for across 3 components.",
            "Since there are 3 separate components, the graph is DISCONNECTED.",
            "",
            "FINAL: DISCONNECTED | 3 connected components: {A,B,C}, {D,E,F}, {G,H}",
        ],
        "Connected = one component (every node can reach every other). Disconnected = multiple components. Use BFS to find all components.",
        math=True)

    # ── P12 ────────────────────────────────────────────────────
    S += Q("12",
        "A complete undirected graph has 8 nodes (K_8). "
        "(a) How many edges does it have? "
        "(b) What is its density? "
        "(c) If we remove 10 edges from K_8, what is the new density?",
        [
            "Part (a) — Edges in K_8:",
            "  Edges = N*(N-1)/2 = 8*7/2 = 28",
            "",
            "Part (b) — Density of K_8:",
            "  Density = 28/28 = 1.00 (complete graph always has density = 1)",
            "",
            "Part (c) — After removing 10 edges:",
            "  Remaining edges = 28 - 10 = 18",
            "  Maximum possible edges still = 28 (N and N-1 did not change)",
            "  New density = 18/28 ≈ 0.643",
            "",
            "FINAL: K_8 has 28 edges, density=1.0 | After removing 10: 18 edges, density≈0.643",
        ],
        "Complete graph K_N: edges = N(N-1)/2, density = 1.0 always. Removing edges reduces density but max_edges in denominator stays the same.",
        math=True)

    # ── P13 ────────────────────────────────────────────────────
    S += Q("13",
        "A bipartite graph connects 5 users {U1,U2,U3,U4,U5} to 4 topics {T1,T2,T3,T4}. "
        "Connections: U1:T1,T2 | U2:T2,T3,T4 | U3:T1,T3 | U4:T2,T4 | U5:T1,T2,T3,T4. "
        "(a) Total edges? (b) Bipartite density? (c) Most popular topic?",
        [
            "Part (a) — Count edges per user:",
            "  U1: T1,T2        → 2",
            "  U2: T2,T3,T4     → 3",
            "  U3: T1,T3        → 2",
            "  U4: T2,T4        → 2",
            "  U5: T1,T2,T3,T4  → 4",
            "  Total edges = 2+3+2+2+4 = 13",
            "",
            "Part (b) — Max bipartite edges: |Users| x |Topics| = 5 x 4 = 20",
            "  Bipartite density = 13/20 = 0.65",
            "",
            "Part (c) — Count users per topic (in-degree of each topic node):",
            "  T1: U1, U3, U5  → 3 users",
            "  T2: U1, U2, U4, U5 → 4 users",
            "  T3: U2, U3, U5  → 3 users",
            "  T4: U2, U4, U5  → 3 users",
            "",
            "FINAL: 13 edges | Density=13/20=0.65 | Most popular topic: T2 (4 users)",
        ],
        "Bipartite max edges = |Set A| x |Set B|. Density = edges / (|A| x |B|). Used in recommendation systems.",
        math=True)

    # ── P14 ────────────────────────────────────────────────────
    S += Q("14",
        "A network of 5 nodes has the following degree sequence: 4, 3, 3, 2, 2. "
        "(a) Is this degree sequence valid (does such a graph exist)? "
        "(b) How many edges would this graph have? "
        "(c) What would its density be?",
        [
            "Part (a) — Validate using the Handshaking Lemma:",
            "  Sum of degrees = 4+3+3+2+2 = 14",
            "  For a valid undirected graph, sum of degrees MUST be even.",
            "  14 is even ✓  →  The degree sequence is valid.",
            "",
            "Part (b) — Number of edges:",
            "  Edges = Sum of degrees / 2 = 14/2 = 7",
            "",
            "Part (c) — Maximum possible edges (N=5):",
            "  Max = 5*4/2 = 10",
            "  Density = 7/10 = 0.70",
            "",
            "FINAL: Valid sequence ✓ | 7 edges | Density = 0.70 (70% — a dense graph)",
        ],
        "Handshaking Lemma check: sum of degrees must be EVEN for a valid undirected graph. If odd → no such graph exists.",
        math=True)

    # ── P15 ────────────────────────────────────────────────────
    S += Q("15",
        "A company social media page has 25,000 followers. "
        "A post receives 1,500 Likes, 400 Comments, and 600 Shares. "
        "(a) Calculate the Engagement Rate. "
        "(b) If the industry average ER is 2%, how does this company compare?",
        [
            "Part (a):",
            "  Total Interactions = Likes + Comments + Shares = 1,500 + 400 + 600 = 2,500",
            "  Engagement Rate = (Total Interactions / Total Followers) x 100%",
            "  ER = (2,500 / 25,000) x 100% = 10%",
            "",
            "Part (b) — Comparison:",
            "  Company ER = 10%  |  Industry average = 2%",
            "  The company's ER is 5 times the industry average — exceptionally strong engagement.",
            "  This indicates the content is highly relevant, well-targeted, and compelling to the audience.",
            "",
            "FINAL: Engagement Rate = 10% | 5x the industry average of 2% — outstanding performance.",
        ],
        "ER = (Likes + Comments + Shares) / Followers x 100%. Typical ER: Facebook 0.5-1%, Instagram 1-3%. Above 5% is excellent.",
        math=True)

    # ── End page ───────────────────────────────────────────────
    S.append(PageBreak())
    end_t = Table([[Paragraph(
        "<b>End of Document</b><br/>"
        "Social Networking &amp; Digital Marketing — Comprehensive Essay Q&amp;A<br/>"
        "Fayoum University | Faculty of Computers &amp; AI | Academic Year 2023/2024<br/>"
        "<i>Best of luck in your exam!</i>",
        ST['cover_s'])]], colWidths=[CONTENT_W])
    end_t.setStyle(TableStyle([
        ('BACKGROUND',    (0,0),(-1,-1), NAVY),
        ('TOPPADDING',    (0,0),(-1,-1), 32),
        ('BOTTOMPADDING', (0,0),(-1,-1), 32),
        ('LEFTPADDING',   (0,0),(-1,-1), 20),
        ('RIGHTPADDING',  (0,0),(-1,-1), 20),
    ]))
    S.append(end_t)
    return S


# ── Build ──────────────────────────────────────────────────────
def footer(canvas, doc):
    canvas.saveState()
    canvas.setFont('Helvetica', 8)
    canvas.setFillColor(SLATE)
    canvas.drawString(MARGIN, 1.0*cm,
        "Social Networking & Digital Marketing — Essay Q&A | Fayoum University 2023/2024")
    canvas.drawRightString(PAGE_W - MARGIN, 1.0*cm, f"Page {doc.page}")
    canvas.restoreState()

OUT = "/mnt/user-data/outputs/Social_Networking_Essay_QA_v2.pdf"
doc = SimpleDocTemplate(OUT, pagesize=A4,
    leftMargin=MARGIN, rightMargin=MARGIN,
    topMargin=MARGIN, bottomMargin=2.2*cm,
    title="Social Networking & Digital Marketing — Essay Q&A",
    author="Fayoum University — Faculty of Computers & AI")

doc.build(build_story(), onFirstPage=footer, onLaterPages=footer)
print(f"Done: {OUT}")

