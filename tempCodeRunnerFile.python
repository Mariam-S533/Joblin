
from reportlab.lib.pagesizes import A4
from reportlab.lib.styles import ParagraphStyle
from reportlab.lib.units import cm
from reportlab.lib import colors
from reportlab.platypus import (SimpleDocTemplate, Paragraph, Spacer,
                                 Table, TableStyle, PageBreak, HRFlowable)
from reportlab.lib.enums import TA_CENTER, TA_JUSTIFY, TA_LEFT

PAGE_W, PAGE_H = A4
MARGIN = 2 * cm
CONTENT_W = PAGE_W - 2 * MARGIN

# ── colours ────────────────────────────────────────────────────
NAVY    = colors.HexColor('#1B2A4A')
BLUE    = colors.HexColor('#1D4ED8')
SKY     = colors.HexColor('#DBEAFE')
DKGREEN = colors.HexColor('#14532D')
LTGREEN = colors.HexColor('#D1FAE5')
AMBER   = colors.HexColor('#78350F')
LTAMBER = colors.HexColor('#FEF3C7')
CRIMSON = colors.HexColor('#7F1D1D')
LTRED   = colors.HexColor('#FEE2E2')
SLATE   = colors.HexColor('#334155')
LTGRAY  = colors.HexColor('#F8FAFC')
WHITE   = colors.white

# ── styles ─────────────────────────────────────────────────────
def styles():
    def P(name, **kw):
        return ParagraphStyle(name, **kw)
    return {
        'cover_h': P('cover_h', fontName='Helvetica-Bold', fontSize=28,
                     textColor=WHITE, alignment=TA_CENTER, leading=36),
        'cover_s': P('cover_s', fontName='Helvetica', fontSize=13,
                     textColor=colors.HexColor('#BAE6FD'),
                     alignment=TA_CENTER, leading=20),
        'cover_i': P('cover_i', fontName='Helvetica', fontSize=11,
                     textColor=WHITE, alignment=TA_CENTER, leading=17),
        'part':    P('part', fontName='Helvetica-Bold', fontSize=15,
                     textColor=WHITE, alignment=TA_CENTER, leading=22),
        'q':       P('q', fontName='Helvetica-Bold', fontSize=11.5,
                     textColor=NAVY, leading=17, leftIndent=5),
        'mq':      P('mq', fontName='Helvetica-Bold', fontSize=11.5,
                     textColor=CRIMSON, leading=17, leftIndent=5),
        'ah':      P('ah', fontName='Helvetica-Bold', fontSize=10,
                     textColor=DKGREEN, leading=14, spaceAfter=3),
        'body':    P('body', fontName='Helvetica', fontSize=10.5,
                     textColor=SLATE, leading=16, leftIndent=8,
                     spaceAfter=3, alignment=TA_JUSTIFY),
        'bullet':  P('bullet', fontName='Helvetica', fontSize=10.5,
                     textColor=SLATE, leading=16, leftIndent=20, spaceAfter=2),
        'step':    P('step', fontName='Helvetica', fontSize=10.5,
                     textColor=SLATE, leading=16, leftIndent=20, spaceAfter=2),
        'final':   P('final', fontName='Helvetica-Bold', fontSize=10.5,
                     textColor=CRIMSON, leading=15, leftIndent=8, spaceAfter=4),
        'tip':     P('tip', fontName='Helvetica-Oblique', fontSize=9,
                     textColor=AMBER, leading=13, leftIndent=8, spaceAfter=8),
        'toc':     P('toc', fontName='Helvetica', fontSize=11,
                     textColor=NAVY, leading=19, leftIndent=14),
        'toch':    P('toch', fontName='Helvetica-Bold', fontSize=13,
                     textColor=NAVY, leading=20, spaceAfter=6),
    }

ST = styles()

# ── layout helpers ─────────────────────────────────────────────
def cell(items, bg, vpad=7, lpad=10):
    rows = [[i] for i in items]
    t = Table(rows, colWidths=[CONTENT_W])
    t.setStyle(TableStyle([
        ('BACKGROUND',    (0,0),(-1,-1), bg),
        ('TOPPADDING',    (0,0),(-1,-1), vpad),
        ('BOTTOMPADDING', (0,0),(-1,-1), vpad),
        ('LEFTPADDING',   (0,0),(-1,-1), lpad),
        ('RIGHTPADDING',  (0,0),(-1,-1), 8),
        ('VALIGN',        (0,0),(-1,-1), 'TOP'),
    ]))
    return t

def banner(text, bg=NAVY):
    t = Table([[Paragraph(text, ST['part'])]], colWidths=[CONTENT_W])
    t.setStyle(TableStyle([
        ('BACKGROUND',    (0,0),(-1,-1), bg),
        ('TOPPADDING',    (0,0),(-1,-1), 10),
        ('BOTTOMPADDING', (0,0),(-1,-1), 10),
        ('LEFTPADDING',   (0,0),(-1,-1), 12),
        ('RIGHTPADDING',  (0,0),(-1,-1), 12),
    ]))
    return t

def Q(num, question, answer_lines, tip='', math=False):
    """
    answer_lines: list of str.
      '-' prefix → bullet point
      'FINAL:' prefix → bold red final-answer line
      '' → small spacer
    """
    out = []
    label = f"Problem {num}" if math else f"Q{num}"
    qsty  = ST['mq'] if math else ST['q']
    qbg   = LTAMBER if math else SKY

    out.append(cell([Paragraph(f"<b>{label}.</b>  {question}", qsty)], qbg, vpad=9))
    out.append(Spacer(1, 4))

    ans_nodes = [Paragraph("<b>Model Answer:</b>", ST['ah'])]
    for line in answer_lines:
        if line == '':
            ans_nodes.append(Spacer(1, 5))
        elif line.startswith('FINAL:'):
            ans_nodes.append(Paragraph(line[6:].strip(), ST['final']))
        elif line.startswith('-'):
            ans_nodes.append(Paragraph(f"&#8226;  {line[1:].strip()}", ST['bullet']))
        else:
            ans_nodes.append(Paragraph(line, ST['body']))
    out.append(cell(ans_nodes, LTGREEN, vpad=7))

    if tip:
        out.append(Paragraph(f"&#9654;  <i>Exam tip: {tip}</i>", ST['tip']))

    out.append(Spacer(1, 9))
    return out


# ══════════════════════════════════════════════════════════════
#  STORY
# ══════════════════════════════════════════════════════════════
def build_story():
    S = []

    # ── Cover ──────────────────────────────────────────────────
    ct = Table([[Paragraph(
        "SOCIAL NETWORKING &amp;<br/>DIGITAL MARKETING",
        ST['cover_h'])]], colWidths=[CONTENT_W])
    ct.setStyle(TableStyle([
        ('BACKGROUND', (0,0),(-1,-1), NAVY),
        ('TOPPADDING', (0,0),(-1,-1), 40),
        ('BOTTOMPADDING', (0,0),(-1,-1), 24),
        ('LEFTPADDING', (0,0),(-1,-1), 16),
        ('RIGHTPADDING', (0,0),(-1,-1), 16),
    ]))
    S.append(ct)
    S.append(Spacer(1, 10))
    for line in [
        "Comprehensive Essay Q&amp;A — Exam Preparation",
        "Fayoum University | Faculty of Computers &amp; Artificial Intelligence",
        "Academic Year 2023 / 2024",
        "All 6 course parts covered | Full model answers included",
        "Graph Theory &amp; SNA mathematical problems with step-by-step solutions",
    ]:
        S.append(Paragraph(line, ST['cover_s']))
        S.append(Spacer(1, 3))
    S.append(Spacer(1, 16))
    S.append(HRFlowable(width='100%', thickness=2, color=BLUE))
    S.append(Spacer(1, 8))
    S.append(Paragraph("Contents", ST['toch']))
    for t in [
        "Part 1 — Introduction to Social Networks &amp; Social Media",
        "Part 2 — Social Media Types, Tools &amp; Platforms",
        "Part 3 — Social Media Strategy &amp; Return on Investment (ROI)",
        "Part 4 — Digital Marketing &amp; Online Advertising",
        "Part 5 — Search Engine Marketing (SEM, SEO, SEA)",
        "Part 6 — Social Network Analysis (SNA) &amp; Graph Mining",
        "Part 7 — Mathematical Problems: Graph Theory &amp; SNA Calculations",
    ]:
        S.append(Paragraph(f"&#9642;  {t}", ST['toc']))
    S.append(PageBreak())

    # ══════════════════════════════════════════════════════════
    # PART 1 — INTRODUCTION TO SOCIAL NETWORKS & SOCIAL MEDIA
    # ══════════════════════════════════════════════════════════
    S.append(banner("PART 1 — INTRODUCTION TO SOCIAL NETWORKS &amp; SOCIAL MEDIA"))
    S.append(Spacer(1, 10))

    S += Q(1,
        "Define 'Social Media'. What are its three essential characteristics?",
        [
            "Social media is a category of media that focuses on participation and peer-to-peer communication between individuals. It provides sites with the capability to develop User-Generated Content (UGC) and to exchange messages and comments between different users.",
            "",
            "Its three essential characteristics are:",
            "- Participation: Users actively create and share content rather than passively consuming it.",
            "- Peer-to-Peer Communication: Interaction flows directly between users, not only from a single central publisher to an audience.",
            "- User-Generated Content (UGC): Content is created, uploaded, and owned by ordinary users — not professional media organisations.",
        ],
        "UGC is a key term. The definition distinguishes social media from traditional 'broadcast' media (TV, radio, print).")

    S += Q(2,
        "What is the difference between Social Media and Social Networking? Provide a concrete example of each.",
        [
            "Social Media is the broad umbrella term encompassing any digital platform that allows users to create, share, and interact with content. It includes all types of platforms from video sharing to blogging to photo publishing.",
            "",
            "Social Networking is a specific sub-type of social media where the emphasis is placed on listening to customers, building relationships, and sharing engaging content. It focuses on connecting people to one another.",
            "",
            "Example of Social Media (not strictly networking): YouTube is primarily a video publishing and consumption platform — the focus is content, not direct relationship-building between users.",
            "",
            "Example of Social Networking: Facebook is built around personal connections and relationship maintenance between users. LinkedIn is built around professional relationship-building. Both emphasise the network of connections, not just the content.",
            "",
            "Key principle: all social networking is a form of social media, but not all social media is social networking.",
        ],
        "Exams often ask this distinction. Remember: social networking = relationship-focused; social media = broader content-focused category.")

    S += Q(3,
        "Explain the evolution of the Web from Web 1.0 to Web 4.0. Compare all four generations across: communication type, user role, core mechanism, and examples.",
        [
            "Web 1.0 — Static Web (Read-Only): Communication was entirely one-way (unidirectional). The user was a passive viewer who could only read content. Content was published by a single source to many passive readers. Core mechanism: static unidirectional publishing. Examples: personal web pages, online encyclopedias, online newspapers.",
            "",
            "Web 2.0 — Social Web (Read-Write): Enabled multi-way communication in all directions simultaneously. Users became active participants who create, share, like, and comment. The core mechanism is user-generated content (UGC). Social media platforms are primarily associated with Web 2.0. Examples: blogs, wikis, Facebook, YouTube.",
            "",
            "Web 3.0 — Semantic Web (Read-Write-Execute): Provides contextual and personalised interaction. Search engines understand the meaning of content, not just keywords. Users become data sources whose behaviour shapes their personalised experience. Core mechanism: meaning-aware, context-sensitive search and recommendation. Examples: intelligent search engines, personalised recommendation feeds.",
            "",
            "Web 4.0 — Intelligent/Symbiotic Web (Read-Write-Execute-Concurrency): Features proactive and predictive interaction. The web anticipates user needs and acts before the user explicitly requests. Core mechanism: proactive recommendation engines linked to social context. Examples: AI-powered systems that suggest content, products, and connections before users search for them.",
        ],
        "The exam table has 5 comparison rows: name, communication type, user role, core mechanism, and examples. Memorise all 4 generations across all 5 rows.")

    S += Q(4,
        "What does UGC stand for? Explain its significance in the context of social media and Web 2.0.",
        [
            "UGC stands for User-Generated Content. It refers to any form of content — text, images, videos, reviews, blog posts, comments — that is created and published by ordinary users of a platform rather than by professional content producers or the platform itself.",
            "",
            "Significance in social media and Web 2.0:",
            "- It transformed the internet from a publishing medium (read-only Web 1.0) into a participatory medium (read-write Web 2.0).",
            "- It dramatically increased the volume and diversity of content online, since millions of users produce content simultaneously.",
            "- It enables authenticity: peer reviews, personal stories, and user tutorials are often more trusted by audiences than corporate content.",
            "- It powers social proof: when users see others recommending a product or service, it influences their purchasing decisions.",
            "- For organisations, UGC provides a low-cost source of brand content and genuine customer insights.",
            "- The limited definition of social media by Kaplan and Haenlein specifically defines it as 'internet-based applications that build on Web 2.0 foundations and allow the creation and exchange of UGC'.",
        ],
        "UGC is central to the 'limited definition' of social media. Always link UGC to Web 2.0 and participation.")

    S += Q(5,
        "Explain the main ADVANTAGES of social media for organisations. Discuss at least FIVE with clear examples.",
        [
            "1. Speed: Social media enables organisations to react to events or share content far faster than any traditional media. A product launch, a crisis response, or a promotional post can go live in seconds. Traditional media (newspapers, TV ads) require days or weeks of production.",
            "",
            "2. Scalability: Organisations can reach millions of people worldwide with a very small budget compared to traditional advertising. Social media removes geographical barriers — a business in Egypt can reach audiences in Europe, Asia, or America without a physical presence there.",
            "",
            "3. Analysing and Monitoring Customer Data (Customer Profiling / Segmentation): Collecting customer data via social media is far cheaper and faster than traditional methods such as face-to-face interviews at railway stations or supermarkets. Social media analytics enables customer profiling (understanding who customers are) and customer segmentation (grouping them by behaviour or interest) at large scale.",
            "",
            "4. Interactivity: Unlike traditional two-way communication (a phone call between two people), social media enables communication between multiple parties simultaneously. Comments sections, group chats, and community forums allow many-to-many interaction — opening opportunities for community discussion and collective problem-solving.",
            "",
            "5. Reach Audience (Amplification): Social media sharing gives 'amplification' to a message. When one person shares a post, it reaches all their followers, who can share further — creating an exponential multiplier effect on reach.",
            "",
            "6. Convert to Sale: Social proof — seeing other users' positive recommendations, reviews, and testimonials — influences purchasing decisions. Conversion can happen directly online or drive traffic to physical stores.",
            "",
            "7. Engage: Long-term social media engagement builds brand loyalty and encourages repeat purchases. Regular interaction with audiences nurtures relationships that sustain revenue over time.",
        ],
        "Acronym: S-S-A-I-R-C-E. The exam may ask for 4 or 5 — always explain each with a real-world example.")

    S += Q(6,
        "Discuss the main DISADVANTAGES (Drawbacks) of social media for organisations. Explain at least THREE.",
        [
            "1. Relatively New — Organisations Still Learning: Social media is a relatively recent phenomenon, and many organisations have not yet mastered how to use it effectively to create business value. There is no single proven formula — strategies that work for one organisation may fail for another. Organisations must invest time and money in experimentation and learning.",
            "",
            "2. Traceable — Privacy and Accountability Risks: Social media content is transparent. Every post, comment, and interaction can be tracked — who said what, when, and from where. While this is useful for analytics, it creates significant privacy risks for users and accountability risks for organisations. A single poorly worded post can go viral and damage a brand's reputation permanently.",
            "",
            "3. Undeletable Content: Social media content is, to a significant degree, impossible to fully remove. Even after an organisation deletes a post, others may have already taken screenshots or electronic backups. Content can resurface years later, making past mistakes difficult to erase.",
            "",
            "4. Privacy Concerns: One of the greatest concerns in social media is the handling of personal data. Users frequently share sensitive personal information without fully understanding how it is collected, stored, and potentially monetised or misused by platforms and third parties.",
        ],
        "Note the irony: each drawback is a 'dark side' of the advantages. Speed → traceable. Scalability → privacy risks. UGC → undeletable.")

    S += Q(7,
        "What is the Social Media Radar? Describe its structure and explain what it reveals about social media strategy.",
        [
            "The Social Media Radar is a strategic visual diagram that maps social media platforms and tools across two dimensions:",
            "- Radial distance from centre: The closer a tool category is to the centre (where the 'Company Site' is located), the more directly important it is to the organisation's core business.",
            "- Segment/sector: Each sector of the radar represents a different category of social media type.",
            "",
            "The radar includes the following sectors (categories):",
            "- Social Networks (inner ring — highest importance): Facebook for consumers; LinkedIn for businesses.",
            "- Social Bookmarking: Reddit, Digg — useful for understanding what content audiences find most engaging.",
            "- Social Publishing: Blogs, wikis, article sites.",
            "- Social Streaming: Photo and video sharing platforms.",
            "- Social Search: Google, Yahoo search-related tools.",
            "- Social Customer Service: Review sites and customer service platforms.",
            "- Social Knowledge: Yahoo Answers, Wikipedia — Q&A and knowledge-sharing sites.",
            "- Social Blogging: Company blogs, forums, Q&A sites.",
            "",
            "What the Radar reveals: It helps organisations identify which social media platforms are most strategically valuable to invest in, and how different platform types relate to one another. Platforms in the inner ring deliver the highest direct business impact.",
        ],
        "The key insight: platforms closer to the centre = more important to the company. Facebook and LinkedIn are in the inner ring (most important for social networking).")

    S += Q(8,
        "Explain 'Social Media as a Multidisciplinary Approach'. Give examples from TWO different academic or professional domains.",
        [
            "Social media is described as multidisciplinary because it is not confined to any single academic field or professional domain. Instead, it intersects with and transforms virtually every discipline — from accountancy to IT, from marketing to education.",
            "",
            "This means that understanding and using social media effectively requires knowledge from multiple fields simultaneously, and each domain uses social media in a distinct way driven by its specific goals.",
            "",
            "Example 1 — Accountancy and Taxation: Social media is used for knowledge sharing within the accounting profession. Tax authorities and accounting organisations use platforms like Twitter, YouTube, and community forums to communicate new tax rules and regulations to accountants and the public. This replaces or supplements traditional methods like printed circulars or conferences.",
            "",
            "Example 2 — IT Management: The IT management domain uses social media primarily to support previous domains (marketing, HR, customer service) and to calculate the ROI (Return on Investment) of social media investments. This involves using analytical techniques of Social Network Analysis to connect social actions (likes, shares, comments) to business actions (leads, sales, efficiency). IT management provides the infrastructure that makes all other social media uses possible.",
        ],
        "The course shows a table: Domain | Social Media Use | Examples. Be able to fill in at least 3-4 rows from memory.")

    S.append(PageBreak())

    # ══════════════════════════════════════════════════════════
    # PART 2 — SOCIAL MEDIA TYPES, TOOLS & PLATFORMS
    # ══════════════════════════════════════════════════════════
    S.append(banner("PART 2 — SOCIAL MEDIA TYPES, TOOLS &amp; PLATFORMS"))
    S.append(Spacer(1, 10))

    S += Q(9,
        "List and explain the 13 types of social media tools. For each, provide an example platform.",
        [
            "The following classification is adapted from Safko and Brake (2009):",
            "",
            "1. Social Communities: Platforms where users reach, listen to, and engage many people. Can be external (customers) or internal (employees). Examples: Facebook, LinkedIn, Google+, Yammer.",
            "",
            "2. Social Text Publishing Tools (Blogs): Long-form written content platforms. Examples: WordPress blogs, Wikipedia, Slideshare, Quora.",
            "",
            "3. Microblogging Tools: Text publishing limited to a small number of characters per post. Examples: Twitter (originally 140 characters), Tumblr.",
            "",
            "4. Social Photo Publishing Tools: Platforms primarily for sharing images and photos. Examples: Pinterest, Instagram, Flickr, Picasa.",
            "",
            "5. Social Audio Publishing Tools: Platforms for sharing music, podcasts, and audio recordings. Examples: Spotify, iTunes, Podcast.com.",
            "",
            "6. Social Video Publishing Tools: Platforms for sharing video content. Video conveys body language — richer than text or audio. Examples: YouTube, Vimeo, Vine.",
            "",
            "7. Social Gaming Tools: Platforms using gamification and online games for brand engagement. Examples: World of Warcraft (branded gaming).",
            "",
            "8. RSS (Really Simple Syndication): Allows users to subscribe to website updates automatically. Examples: RSS 2.0, Google FeedBurner.",
            "",
            "9. Live Casting Tools: Real-time video broadcasting platforms, typically free. Examples: Live365, Justin.tv.",
            "",
            "10. Virtual World Tools: Immersive 3D environments for meetings, press conferences, and brand experiences. Examples: Second Life, Kaneva.",
            "",
            "11. Mobile Tools: Location-based and mobile-specific social platforms. Examples: Foursquare, Swarm.",
            "",
            "12. Productivity Tools: Tools enhancing social event management, surveys, alerts, cloud documents. Examples: SurveyMonkey, Doodle, Google Docs.",
            "",
            "13. Aggregators: Gather content from multiple sources into one personalised overview. Examples: MyYahoo, iGoogle.",
        ],
        "All 13 types are examinable. Group them mentally: content types (text/photo/audio/video), community tools, utility tools (RSS/aggregators/productivity), and immersive tools (gaming/virtual worlds).")

    S += Q(10,
        "What is Microblogging? Describe Twitter as a microblogging platform and explain all key Twitter vocabulary terms.",
        [
            "Microblogging is a category of social text publishing that differs from standard blogging by strictly limiting the number of characters per post. This brevity forces users to be concise and promotes real-time, frequent updates.",
            "",
            "Twitter (now known as X) is the most prominent microblogging platform. Its posts, called 'tweets', were originally limited to 140 characters — matching the length of SMS text messages — making Twitter compatible with mobile communication.",
            "",
            "Key Twitter vocabulary:",
            "- Tweet: A Twitter post. The core unit of content on the platform.",
            "- @Username (the 'at' sign): Tags a specific Twitter user, sending them a notification. Example: @McDonalds refers directly to McDonald's account.",
            "- Tweep: A person who follows someone else's tweets (a Twitter follower).",
            "- RT / Retweet: Reposting another user's tweet, giving it credit and extending its reach to your own followers.",
            "- #topic / Hashtag: Indicates the topic or keyword of a tweet and groups all tweets using that hashtag into a searchable feed. Example: #jobvacancy groups all job-related posts. Hashtags make content discoverable to users not already following the poster.",
            "",
            "Importance: Twitter is classified as a 'Social News' platform in the Social Media Radar — it is the best-known platform for real-time news sharing and trending topic discussion.",
        ],
        "Memorise all 5 vocabulary terms: tweet, @username, tweep, RT/retweet, #hashtag. The 140-character limit is a specific detail examiners test.")

    S += Q(11,
        "What are Social Communities? Distinguish between communities created for EXTERNAL use and communities created for INTERNAL use, with examples of each.",
        [
            "Social Communities are social media platforms and spaces where community members can reach many people, listen to them, and get them actively involved. The core goals of social communities are:",
            "- To engage customers, suppliers, and external partners.",
            "- To collect feedback, ideas, and opinions.",
            "- To build relationships and brand loyalty.",
            "",
            "Communities Created for External Use: These are public-facing communities where organisations interact with customers, prospects, and partners. They are designed to build brand presence, handle customer service, gather market feedback, and drive sales.",
            "Example: A company's Facebook Page where customers post product reviews, ask questions, and share experiences. The page is visible to the public and serves marketing and customer service functions simultaneously.",
            "",
            "Communities Created for Internal Use: These are private communities within an organisation, designed to stimulate collaboration between employees, share knowledge, communicate company rules and processes, and improve collective productivity.",
            "Example: A company using Yammer (Microsoft's enterprise social network) to allow employees across different offices and departments to share project updates, best practices, and company announcements without using email.",
            "",
            "Both types leverage the power of many-to-many communication — replacing one-to-one or one-to-many communication models of older tools.",
        ],
        "External = customer/market-facing. Internal = employee collaboration (sometimes called 'intranet' or 'enterprise social network'). Both are 'social communities'.")

    S += Q(12,
        "What is Gamification? How do organisations use Social Gaming and Gamification in marketing strategy?",
        [
            "Gamification is the application of game-design thinking and game mechanics to real-life, non-game contexts. It applies elements such as points, badges, leaderboards, challenges, and progress bars to ordinary activities to stimulate competition, engagement, and motivation.",
            "",
            "Crucially, gamification does NOT mean creating video games. It means turning real situations into competitive or achievement-based experiences. Customers or users are stimulated to do more of something or to do it better than others.",
            "",
            "How organisations use Social Gaming and Gamification:",
            "- Brand Recognition through Game Sponsorship: Organisations participate in or sponsor existing popular online games to embed their brand in the gaming experience.",
            "- Customer Loyalty Programmes: Rewarding customers with points, digital badges, or tier-based status for purchases, reviews, or shares — making loyalty feel like a game with progression.",
            "- Branded Mobile Games: Developing mobile apps that entertain users while promoting products. Example: a food brand creating a cooking mini-game.",
            "- Product Promotion: Organisations create in-game events, branded characters, or sponsored challenges. Example: World of Warcraft is cited in the course as an example of social gaming for brand promotion.",
            "- Employee Engagement: Internally, gamification can motivate employees through sales leaderboards, training completion badges, and peer recognition systems.",
        ],
        "Gamification ≠ games. Gamification = game MECHANICS applied to real situations. The keyword is 'stimulate competition and engagement'.")

    S += Q(13,
        "What are Aggregators? What is their purpose, and why are they useful for both users and organisations?",
        [
            "Aggregators are websites or applications that gather, collect, and combine content and information from multiple different online sources into a single, personalised interface for the user. Instead of visiting each website, social media platform, email inbox, or news site separately, the user sees a unified personalised feed of relevant new content from all their chosen sources in one place.",
            "",
            "An aggregated overview may include:",
            "- Incoming emails and notifications",
            "- Personal agenda and calendar events",
            "- News items and weather forecasts",
            "- Latest posts from favourite blogs",
            "- Updates from social media accounts",
            "",
            "Usefulness for users: Aggregators save time by eliminating the need to check dozens of websites individually. They give a personalised, relevant, and current view of everything the user cares about.",
            "",
            "Usefulness for organisations: Aggregators help organisations monitor what is being said about their brand across multiple platforms simultaneously. Social media monitoring via aggregation tools enables real-time brand listening and faster response to customer feedback or crisis events.",
            "",
            "Examples: MyYahoo, iGoogle (until 2013), Feedly, Bloglovin' (fashion/lifestyle blogs).",
        ],
        "Aggregators are both a productivity tool (for users) and a monitoring/listening tool (for organisations). They are classified as one of the 13 social media tool types.")

    S += Q(14,
        "Explain the purpose of Podcasts and Audio Publishing tools. How can organisations use them strategically?",
        [
            "The term 'podcast' is derived from combining 'iPod' and 'broadcast'. A podcast is a series of audio (or sometimes video) episodes that users can download or stream from a website — similar to a serialised radio show or digital magazine.",
            "",
            "Podcasts differ from single audio recordings in that they consist of multiple episodes published regularly over time. They can cover audio, radio content, video, MP3, or other media formats.",
            "",
            "Audio publishing tools are the broader category of social media platforms for sharing any audio content — from music to spoken word to podcasts. Key platforms include Spotify, iTunes, and Podcast.com.",
            "",
            "Strategic uses for organisations:",
            "- Thought Leadership: Publishing expert interview podcasts positions the organisation as an authority in its field.",
            "- Content Marketing: Educational podcast series attract and retain a loyal audience who associate the brand with expertise.",
            "- Brand Storytelling: Audio storytelling creates an intimate, personal connection with listeners — especially effective during commutes or exercise when video/text cannot be consumed.",
            "- Customer Education: Tutorials and how-to audio content support customers after purchase.",
            "- Employee Training: Internal podcasts deliver training content to employees at their own pace and convenience.",
        ],
        "Remember: podcast = iPod + broadcast. It is a SERIES of episodes, not a single recording. Audio publishing includes music platforms (Spotify) AND podcast platforms.")

    S.append(PageBreak())

